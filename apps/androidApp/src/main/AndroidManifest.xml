<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- ADR 0044 Phase B — LOCAL notifications (no FCM/APNs). Runtime-requested on API 33+ via the
         opt-in notification ladder; the app works fully if denied (reminders just wait inside Now). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- ADR 0044 Phase B — background proximity (opt-in, reversible, default-off). FINE is the
         while-using grant primed first; BACKGROUND is the separate "Always" upgrade. RECEIVE_BOOT +
         SCHEDULE_EXACT_ALARM re-arm geofences + fire known-future-instant reminders. Matched on-device;
         the live position never leaves the phone (ADR 0014). -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-feature android:name="android.hardware.location" android:required="false" />
    <!-- S6-D Tier 2: in-app QR scanner (requested at runtime; camera is optional so
         the app still installs on camera-less devices → enter-code fallback). -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera.any" android:required="false" />

    <application
        android:enableOnBackInvokedCallback="true"
        android:label="Dayfold"
        android:usesCleartextTraffic="true"
        android:theme="@android:style/Theme.Material.Light.NoActionBar">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- S6-D Tier 2: verified App Link for the device-approval deep link.
                 Opens https://<api-origin>/device?user_code=… straight into the app
                 (verified against /.well-known/assetlinks.json on that origin). -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https"
                    android:host="family-ai-dashboard.vercel.app"
                    android:path="/device" />
            </intent-filter>
        </activity>

        <!-- ADR 0044 Phase B — headless background receivers. Geofence + exact-alarm fire via internal
             PendingIntents (not exported). Boot/app-update re-arm geofences (protected system broadcasts). -->
        <receiver
            android:name=".GeofenceReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.sloopworks.dayfold.GEOFENCE_EVENT" />
            </intent-filter>
        </receiver>
        <receiver
            android:name=".ExactAlarmReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.sloopworks.dayfold.EXACT_ALARM" />
            </intent-filter>
        </receiver>
        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
