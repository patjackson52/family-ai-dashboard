{
  "name": "@sloopworks/api",
  "private": true,
  "version": "0.0.0-M0",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "build:fn": "esbuild src/vercel-entry.ts --bundle --platform=node --format=esm --outfile=api/index.js --packages=external",
    "db:check": "node scripts/schema-drift.mjs",
    "db:migrate": "node scripts/migrate.mjs",
    "env:check": "node scripts/env-check.mjs",
    "preflight": "node scripts/env-check.mjs && node scripts/schema-drift.mjs"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "hono": "^4.6.0",
    "jose": "^5.9.0",
    "pg": "^8.13.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.9"
  }
}
