{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://family-ai-dashboard/schemas/content.schema.json",
  "title": "family-ai-dashboard content contract (M0)",
  "description": "SINGLE SOURCE OF TRUTH (ADR 0006; 'schema wins over prose'). Codegen emits TS (zod) + Kotlin types from this (03-api/07-cli/08-client). RESOLVED 2026-06-18 (INB-10): M0 = PLAINTEXT — CONTENT fields (title, body_md, payload, triggers, actions, place label/lat/lng) use the plain types below; schema is FROZEN for M0. The `EncryptedEnvelope` $def is M1-only (live E2EE per ADR 0015/0017) and replaces each CONTENT field's plain type IF/when adopted. M0 surface = briefing-card feed (D2); Hub/Section/Block stay in the schema (authorable, dormant render). NOTE: define the `payload` per-block-type $defs before codegen (gaps review C4).",

  "$defs": {
    "ulid":        { "type": "string", "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$", "description": "client-supplied stable id (07 deterministic-id rule)" },
    "timestamp":   { "type": "string", "format": "date-time" },
    "version":     { "type": "integer", "minimum": 1, "description": "M0: server-bumps. E2E: client-supplies, server validates monotonic (02/07)." },

    "Provenance": {
      "type": "object",
      "required": ["source", "at"],
      "properties": {
        "source": { "type": "string", "description": "claude | email | user | <url>" },
        "at": { "$ref": "#/$defs/timestamp" },
        "credential_id": { "type": "string", "description": "which credential pushed this (audit)" }
      },
      "additionalProperties": false
    },

    "Trigger": {
      "description": "ADR 0014 — matched ON-DEVICE; live position never leaves.",
      "oneOf": [
        { "type": "object", "required": ["geo"], "properties": { "geo": { "type": "object", "properties": {
            "place_ref": { "type": "string" }, "lat": { "type": "number" }, "lng": { "type": "number" },
            "radius_m": { "type": "integer", "default": 150 }, "label": { "type": "string" } } } }, "additionalProperties": false },
        { "type": "object", "required": ["when"], "properties": { "when": { "type": "object", "properties": {
            "at": { "$ref": "#/$defs/timestamp" }, "window": { "type": "object" },
            "relative": { "type": "string" }, "recurring": { "type": "string" }, "alert_offset": { "type": "string" } } } }, "additionalProperties": false },
        { "type": "object", "required": ["activity"], "properties": { "activity": { "type": "object", "properties": {
            "kind": { "enum": ["walking", "running", "biking", "driving"] } } } }, "additionalProperties": false, "description": "schema slot; matching DEFERRED" }
      ]
    },

    "Action": {
      "description": "ADR 0016 RESERVED (bounded-now: buttons + structured asks; not built at MVP).",
      "type": "object",
      "required": ["label", "action_id"],
      "properties": { "label": { "type": "string" }, "action_id": { "type": "string" }, "params": { "type": "object" } },
      "additionalProperties": false
    },

    "LinkPayload":     { "type": "object", "required": ["url"], "properties": { "url": { "type": "string", "format": "uri" }, "label": { "type": "string" }, "source": { "type": "string" }, "thumbnailUrl": { "type": "string", "format": "uri", "maxLength": 2048, "description": "link preview image; https + allowlisted host (ADR 0036)" }, "thumbnailAlt": { "type": "string", "maxLength": 256, "description": "a11y alt for thumbnailUrl" } }, "additionalProperties": false },
    "ChecklistPayload":{ "type": "object", "required": ["items"], "properties": { "items": { "type": "array", "items": { "type": "object", "required": ["text"], "properties": { "text": { "type": "string" }, "done": { "type": "boolean", "default": false }, "due": { "$ref": "#/$defs/timestamp" }, "assignee": { "type": "string" } }, "additionalProperties": false } } }, "additionalProperties": false },
    "DocumentPayload": { "type": "object", "required": ["ref"], "properties": { "ref": { "type": "string", "description": "url | fileRef (links+small refs at MVP)" }, "label": { "type": "string" }, "kind": { "type": "string" }, "thumbnailUrl": { "type": "string", "format": "uri", "maxLength": 2048, "description": "document preview image; https + allowlisted host (ADR 0036)" }, "thumbnailAlt": { "type": "string", "maxLength": 256, "description": "a11y alt for thumbnailUrl" } }, "additionalProperties": false },
    "MilestonePayload":{ "type": "object", "required": ["date", "label"], "properties": { "date": { "$ref": "#/$defs/timestamp" }, "label": { "type": "string" } }, "additionalProperties": false },
    "ContactPayload":  { "type": "object", "required": ["name"], "properties": { "name": { "type": "string" }, "role": { "type": "string" }, "phone": { "type": "string" }, "email": { "type": "string" }, "avatarUrl": { "type": "string", "format": "uri", "maxLength": 2048, "description": "contact avatar photo; https + allowlisted host (ADR 0036); falls back to initials" }, "accentColor": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "description": "decorative-only accent seed (ADR 0036)" } }, "additionalProperties": false },
    "LocationPayload": { "type": "object", "required": ["label"], "properties": { "label": { "type": "string" }, "address": { "type": "string" }, "mapUrl": { "type": "string" } }, "additionalProperties": false },
    "BudgetPayload":   { "type": "object", "required": ["items"], "properties": { "items": { "type": "array", "items": { "type": "object", "required": ["label", "amount"], "properties": { "label": { "type": "string" }, "amount": { "type": "number" }, "paid": { "type": "boolean", "default": false } }, "additionalProperties": false } } }, "additionalProperties": false },

    "Block": {
      "type": "object",
      "required": ["id", "type", "provenance"],
      "$comment": "payload variant is bound by `type`: link→LinkPayload, checklist→ChecklistPayload, document→DocumentPayload, milestone→MilestonePayload, contact→ContactPayload, location→LocationPayload, budget→BudgetPayload. text/markdown use body_md, no payload. Codegen emits the discriminated union.",
      "properties": {
        "id": { "$ref": "#/$defs/ulid" },
        "type": { "enum": ["text", "markdown", "link", "checklist", "document", "milestone", "contact", "location", "budget"] },
        "ord": { "type": "integer", "default": 0 },
        "version": { "$ref": "#/$defs/version" },
        "body_md": { "type": "string", "maxLength": 1048576, "description": "long-form markdown (text/markdown blocks); inline ≤1MB at M0, else spill to body_ref (06, M1)" },
        "body_ref": { "type": "string", "description": "object-storage KEY when spilled (M1); never a URL; XOR with body_md" },
        "payload": { "description": "structured fields for non-markdown block types; variant by `type` (see $comment)",
          "oneOf": [ { "$ref": "#/$defs/LinkPayload" }, { "$ref": "#/$defs/ChecklistPayload" }, { "$ref": "#/$defs/DocumentPayload" }, { "$ref": "#/$defs/MilestonePayload" }, { "$ref": "#/$defs/ContactPayload" }, { "$ref": "#/$defs/LocationPayload" }, { "$ref": "#/$defs/BudgetPayload" } ] },
        "triggers": { "type": "array", "items": { "$ref": "#/$defs/Trigger" } },
        "actions": { "type": "array", "items": { "$ref": "#/$defs/Action" } },
        "provenance": { "$ref": "#/$defs/Provenance" }
      },
      "additionalProperties": false,
      "allOf": [ { "$comment": "body_md XOR body_ref (02 CHECK)" } ]
    },

    "Section": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "$ref": "#/$defs/ulid" }, "title": { "type": "string", "description": "[CONTENT/E2E-hole]" },
        "ord": { "type": "integer", "default": 0 }, "version": { "$ref": "#/$defs/version" },
        "blocks": { "type": "array", "items": { "$ref": "#/$defs/Block" } }
      },
      "additionalProperties": false
    },

    "Hub": {
      "type": "object",
      "required": ["id", "type", "title"],
      "properties": {
        "id": { "$ref": "#/$defs/ulid" },
        "type": { "type": "string", "description": "bounded template-catalog key (ADR 0004/0006): vacation|starting-college|move|party-event|new-baby|medical|school-year — app-validated" },
        "title": { "type": "string", "description": "[CONTENT/E2E-hole]" },
        "status": { "enum": ["planning", "active", "archived"], "default": "active" },
        "start_at": { "$ref": "#/$defs/timestamp" }, "end_at": { "$ref": "#/$defs/timestamp" }, "countdown_to": { "$ref": "#/$defs/timestamp" },
        "version": { "$ref": "#/$defs/version" },
        "sections": { "type": "array", "items": { "$ref": "#/$defs/Section" } },
        "media": {
          "description": "visual enrichment (ADR 0036; all optional, absent = unenriched/today's look). URLs are https + allowlisted-host (ADR 0036 shared validator); icon ∈ curated set; accentColor is decorative-only.",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "heroUrl": { "type": "string", "format": "uri", "maxLength": 2048, "description": "hero image (Hub detail header + list-row fallback). https + allowlisted host." },
            "thumbnailUrl": { "type": "string", "format": "uri", "maxLength": 2048, "description": "list-row 1:1 thumbnail; absent → falls back to heroUrl client-side." },
            "heroFit": { "enum": ["cover", "contain"], "description": "cover=photo edge-to-edge crop; contain=logo letterboxed on accent tint." },
            "imageAlt": { "type": "string", "maxLength": 256, "description": "a11y alt → contentDescription (else derived from title)." },
            "icon": { "type": "string", "maxLength": 40, "description": "curated icon NAME, server-validated vs the bundled set (ADR 0036); unknown → fallback tile." },
            "accentColor": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "description": "decorative-only accent seed (edge/tile/chip/scrim); never body text (WCAG 1.4.1). Lowercased on write." }
          }
        }
      },
      "additionalProperties": false
    },

    "BriefingCard": {
      "description": "the 'Now' surface",
      "type": "object",
      "required": ["id", "kind", "title", "provenance"],
      "properties": {
        "id": { "$ref": "#/$defs/ulid" },
        "kind": { "enum": ["action", "info", "weather", "countdown"], "default": "info" },
        "title": { "type": "string", "maxLength": 4096 },
        "body_md": { "type": "string", "maxLength": 1048576, "description": "limited inline markdown only (1MB cap, F8)" },
        "target": { "type": "object", "description": "deep-link into a hub (resolved client-side vs local cache, nearest-ancestor)",
          "properties": { "hubId": { "type": "string" }, "sectionId": { "type": "string" }, "blockId": { "type": "string" } }, "additionalProperties": false },
        "triggers": { "type": "array", "items": { "$ref": "#/$defs/Trigger" } },
        "actions": { "type": "array", "items": { "$ref": "#/$defs/Action" } },
        "not_before": { "$ref": "#/$defs/timestamp" }, "expires_at": { "$ref": "#/$defs/timestamp" },
        "version": { "$ref": "#/$defs/version" }, "provenance": { "$ref": "#/$defs/Provenance" },

        "type": { "enum": ["file", "link", "invite", "contact", "geo", "email"], "description": "content type (ADR 0022 D1) — drives the Now-card / detail layout. OPTIONAL for back-compat with kind-only M0 cards." },
        "media": {
          "description": "card visual enrichment (ADR 0036; all optional). icon+accent on the kind chip + optional leading thumbnail. Same shared URL/host/icon/hex validation as Hub.media.",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "icon": { "type": "string", "maxLength": 40, "description": "curated icon NAME (server-validated); unknown → fallback." },
            "accentColor": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "description": "decorative-only accent seed; never body text. Lowercased on write." },
            "thumbnailUrl": { "type": "string", "format": "uri", "maxLength": 2048, "description": "optional leading thumbnail; https + allowlisted host." },
            "imageAlt": { "type": "string", "maxLength": 256, "description": "a11y alt for thumbnailUrl." },
            "imageFit": { "enum": ["cover", "contain"] }
          }
        },
        "hubRef": { "type": "string", "description": "parent Hub id — the adaptive supporting pane's 'PART OF THIS HUB' (ADR 0022; CL-10). Optional." },
        "relatedKicker": { "type": "string", "description": "section header for the RELATED rows (e.g. 'FROM THE SAME EMAIL'). CL-8." },
        "related": { "type": "array", "description": "cross-links to other cards in THIS family (CL-8). targetId resolves client-side vs the local cache; title/sub are author-denormalized so a row renders without resolving. Same-tenant only (rides authorizeTenant).",
          "items": { "type": "object", "additionalProperties": false, "required": ["relation", "targetId", "targetType"],
            "properties": {
              "relation": { "type": "string", "description": "same-email | same-thread | same-hub | same-trip | attachment | contact-of" },
              "targetId": { "type": "string" },
              "targetType": { "enum": ["file", "link", "invite", "contact", "geo", "email"] },
              "title": { "type": "string" }, "sub": { "type": "string" }
            } } },
        "privacy": { "type": "object", "additionalProperties": false, "description": "honesty chip (ADR 0014/0015) — a claim allowed ONLY where a real schema/API/client boundary enforces it.",
          "properties": { "storage": { "enum": ["on_device", "in_browser", "location_local", "matched_on_device"] } } },
        "payload": { "description": "[E2E-ciphertext at M1] typed content payload, variant selected by `type` (ADR 0022 D1). Inline oneOf (no internal $ref) so codegen emits TYPED variants, never z.any.",
          "oneOf": [
            { "type": "object", "required": ["file"], "additionalProperties": false, "properties": { "file": { "type": "object", "additionalProperties": false, "properties": {
              "filename": { "type": "string" }, "mime": { "type": "string" }, "size": { "type": "integer" }, "pages": { "type": "integer" },
              "source": { "type": "string" }, "owner": { "type": "string" }, "modified": { "type": "string", "format": "date-time" },
              "sharedWith": { "type": "array", "items": { "type": "string" } }, "docRef": { "type": "string", "description": "url | opaque storage ref" } } } } },
            { "type": "object", "required": ["link"], "additionalProperties": false, "properties": { "link": { "type": "object", "additionalProperties": false, "properties": {
              "url": { "type": "string", "format": "uri" }, "domain": { "type": "string" }, "title": { "type": "string" }, "ogDesc": { "type": "string", "description": "author-stamped OG; server never fetches the URL (no SSRF)" },
              "favicon": { "type": "string" }, "kind": { "enum": ["page", "form"] }, "fieldCount": { "type": "integer" }, "closesAt": { "type": "string", "format": "date-time" }, "savedAt": { "type": "string", "format": "date-time" } } } } },
            { "type": "object", "required": ["invite"], "additionalProperties": false, "properties": { "invite": { "type": "object", "additionalProperties": false, "properties": {
              "eventName": { "type": "string" }, "host": { "type": "string" }, "startAt": { "type": "string", "format": "date-time" }, "place": { "type": "string" },
              "rsvpBy": { "type": "string", "format": "date-time" }, "rsvpState": { "enum": ["yes", "no", "none"], "description": "display-of-state at M0 (no write path; ADR 0020/0016)" },
              "guestCount": { "type": "integer" }, "confirmedCount": { "type": "integer" }, "notes": { "type": "string" } } } } },
            { "type": "object", "required": ["contact"], "additionalProperties": false, "properties": { "contact": { "type": "object", "additionalProperties": false, "properties": {
              "name": { "type": "string" }, "company": { "type": "string" }, "role": { "type": "string" }, "phone": { "type": "string" }, "email": { "type": "string" },
              "address": { "type": "string" }, "hours": { "type": "string" }, "linkedEventId": { "type": "string" }, "deliveryWindow": { "type": "string" } } } } },
            { "type": "object", "required": ["geo"], "additionalProperties": false, "properties": { "geo": { "type": "object", "additionalProperties": false, "properties": {
              "label": { "type": "string" }, "address": { "type": "string" }, "lat": { "type": "number" }, "lng": { "type": "number" },
              "etaMin": { "type": "integer" }, "distance": { "type": "string" }, "travelMode": { "type": "string" }, "parking": { "type": "string" },
              "leaveBy": { "type": "string", "format": "date-time" }, "linkedEventId": { "type": "string" } } } } },
            { "type": "object", "required": ["email"], "additionalProperties": false, "properties": { "email": { "type": "object", "additionalProperties": false, "properties": {
              "from": { "type": "string" }, "fromAddr": { "type": "string" }, "subject": { "type": "string" }, "date": { "type": "string", "format": "date-time" },
              "threadLen": { "type": "integer" }, "bodyExcerpt": { "type": "string", "description": "[E2E-ciphertext] authored over the operator's OWN mail (CLI/Claude) — never a server-side Gmail restricted-scope read (Guardrail 3)" },
              "attachments": { "type": "array", "items": { "type": "object", "additionalProperties": false, "properties": { "name": { "type": "string" }, "mime": { "type": "string" }, "size": { "type": "integer" } } } },
              "labels": { "type": "array", "items": { "type": "string" } } } } } }
          ] }
      },
      "additionalProperties": false
    },

    "Place": {
      "description": "ADR 0014 reusable named place; family content (encrypted at rest, never live position)",
      "type": "object",
      "required": ["id", "label", "lat", "lng"],
      "properties": {
        "id": { "$ref": "#/$defs/ulid" }, "label": { "type": "string" },
        "kind": { "enum": ["home", "school", "store", "other"], "default": "other", "description": "category (drives the place icon in the UI; design alignment)" },
        "lat": { "type": "number" }, "lng": { "type": "number" },
        "radius_m": { "type": "integer", "default": 150 }, "version": { "$ref": "#/$defs/version" }
      },
      "additionalProperties": false
    },

    "EncryptedEnvelope": {
      "description": "[E2E mode, ADR 0015] replaces each CONTENT field's plain type when E2E is accepted. AEAD ciphertext; AAD=(family_id, id, version) bound by the writer (07) and verified by the reader.",
      "type": "object",
      "required": ["ct", "nonce", "alg"],
      "properties": { "ct": { "type": "string", "contentEncoding": "base64" }, "nonce": { "type": "string", "contentEncoding": "base64" }, "alg": { "type": "string", "default": "xchacha20poly1305" } },
      "additionalProperties": false
    },

    "SyncResponse": {
      "description": "GET /families/{fid}/sync (03 §sync)",
      "type": "object",
      "required": ["changes", "tombstones", "has_more"],
      "properties": {
        "changes": { "type": "object", "properties": {
          "hubs": { "type": "array", "items": { "$ref": "#/$defs/Hub" } },
          "sections": { "type": "array", "items": { "$ref": "#/$defs/Section" } },
          "blocks": { "type": "array", "items": { "$ref": "#/$defs/Block" } },
          "cards": { "type": "array", "items": { "$ref": "#/$defs/BriefingCard" } },
          "places": { "type": "array", "items": { "$ref": "#/$defs/Place" } } } },
        "tombstones": { "type": "array", "items": { "type": "object", "required": ["type", "id"],
          "properties": { "type": { "enum": ["hub", "section", "block", "card", "place"] }, "id": { "type": "string" } }, "additionalProperties": false } },
        "next_cursor": { "type": "string" }, "has_more": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  }
}
